# OS / editor junk
.DS_Store
Thumbs.db
*.log

# Secrets (нет в проекте, но на всякий случай — секреты только в .env)
.env
.env.*
!.env.example

# Dependencies (если появятся)
node_modules/

# Terraform (состояние и секреты — только локально)
infra/.terraform/
infra/.terraform.lock.hcl
*.tfstate
*.tfstate.*
crash.log
terraform.tfvars
*.auto.tfvars

# SSH-ключи / service-account JSON — никогда в git
*.pem
*.key
*-key.json
